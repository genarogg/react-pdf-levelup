{
  "name": "@react-pdf-levelup/cli",
  "version": "1.0.0",
  "description": "CLI para react-pdf-levelup con Studio playground",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "react-pdf-levelup": "dist/bin.js"
  },
  "private": false,
  "files": [
    "dist",
    "public",
    "README.md"
  ],
  "scripts": {
    "build:lib": "tsup --config tsup.config.ts",
    "copy:frontend": "node scripts/copy-frontend.js",
    "build": "npm run build:lib && npm run copy:frontend",
    "publicar": "npm run build && node ../scripts/index.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "open": "^10.1.0",
    "serve-handler": "^6.1.6"
  },
  "devDependencies": {
    "@types/node": "^25.9.4",
    "@types/serve-handler": "^6.1.4",
    "fs-extra": "^11.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
