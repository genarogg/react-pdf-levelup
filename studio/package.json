{
  "name": "@react-pdf-levelup/studio",
  "version": "1.0.0",
  "description": "CLI para react-pdf-levelup con Studio playground",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "react-pdf-levelup": "dist/bin.js"
  },
  "private": false,
  "files": [
    "dist",
    "playground",
    "README.md"
  ],
  "scripts": {
    "build:lib": "tsup --config tsup.config.ts",

    "build:studio": "npm run build --prefix ../frontend && node scripts/copy-playground.js",
    "build": "npm run build:lib && npm run build:studio"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "open": "^10.1.0",
    "mime-types": "^2.1.35"
  },
  "devDependencies": {
    "@types/node": "^25.9.4",
    "@types/mime-types": "^2.1.4",
    "fs-extra": "^11.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
