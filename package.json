{
  "name": "monorepo",
  "version": "1.0.0",
  "private": false,
  "description": "react-pdf-levelup: Generador dinámico de PDFs con componentes React. Incluye editor en vivo, plantillas predefinidas y API REST. Stack: Turborepo, React + Vite (frontend), Fastify (API), Astro (documentación)",
  "type": "module",
  "engines": {
    "node": "22"
  },
  "workspaces": [
    "frontend",
    "docs",
    "lib",
    "api"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build --filter=frontend --filter=docs --filter=api",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "-----lib-----": "-----------------------------------------",
    "publish-all": "cd lib && pnpm run publish-all",
    "demo:frontend": "cd frontend && pnpm run demo",
    "demo:api": "cd api && pnpm run demo",
    "zip:api": "node ./global/zip-api.js",
    "-----Global-----": "-----------------------------------------",
    "clean:install": "node ./global/clean.js && pnpm install"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "turbo": "^2.7.2"
  },
  "packageManager": "pnpm@8.15.0"
}